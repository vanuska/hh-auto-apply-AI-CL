# Виртуальное окружение
.venv/
venv/

# Python кеш
__pycache__/
*.pyc

# IDE
.vscode/
.idea/
.DS_Store

# Переменные окружения (содержат API-ключи!)
.env
.env.local

# Личные данные пользователя
my/
!my/.gitkeep

# База данных (содержит историю откликов)
data/
!data/.gitkeep

# Логи
*.log

# Бэкапы
*.bak
*.backup

# Временные файлы
*.tmp
*.swp
*.swo

# Файлы резюме (личные данные)
*.pdf
*.doc
*.docx
*.rtf
*.txt
